rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ⚠️ DESENVOLUPAMENT/PROTOTIP: regles obertes.
    //
    // Com que l'app usa autenticació custom (no Firebase Auth),
    // Firestore no pot saber qui està fent la petició. Això vol dir
    // que qualsevol usuari amb Internet pot llegir i escriure a la DB.
    //
    // Per a producció real cal una de dues opcions:
    //
    // 1) Migrar AuthContext a Firebase Auth i escriure regles com:
    //      allow read: if true;
    //      allow write: if request.auth != null &&
    //                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.administrar == true;
    //
    // 2) Mantenir les regles permissives però accedir per Cloud Functions
    //    (backend) amb Firebase Admin SDK.
    //
    // Per al llançament inicial, mantenim les regles obertes per
    // simplicitat. El risc és acotat si la URL de l'app no és pública.

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
