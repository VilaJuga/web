# Copia aquest fitxer a `.env.local` i omple els valors reals.
# En dev (npm run dev) l'app es connecta als emuladors locals,
# així que els valors de Firebase només calen per fer build + deploy a producció.

# ── Firebase (Project settings → General → Your apps → Web app → firebaseConfig) ──
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── EmailJS (opcional, per al formulari de contacte) ──
# Obtén-los a https://www.emailjs.com/ després de crear un service i template.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# ── Credencials per defecte (info, no cal canviar) ──
# Superadmin: Gioconda / MonaLisa
# Contrasenya per defecte d'usuaris nous: VilajugaAdmin
